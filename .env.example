# =============================================================================
# AI Assistant POC — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit the .env file to version control.
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI (REQUIRED)
# Get your API key at: https://platform.openai.com/api-keys
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=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

# ──────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL with pgvector)
# ──────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ragdb
DB_USER=postgres
DB_PASSWORD=postgres

# ──────────────────────────────────────────────────────────────────────────────
# JWT — MUST be changed in production
# Generate a 256-bit base64 secret:
#   openssl rand -base64 32
# ──────────────────────────────────────────────────────────────────────────────
JWT_SECRET=bXlTdXBlclNlY3JldEtleUZvckpXVEF1dGhlbnRpY2F0aW9uMTIz

# ──────────────────────────────────────────────────────────────────────────────
# AES-256 Encryption Key for connector credentials at rest
# Generate with:
#   python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# ──────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=bXlTdXBlclNlY3JldEVuY3J5cHRpb25LZXkxMjM0NTY3OA==

# ──────────────────────────────────────────────────────────────────────────────
# SMTP (for EmailSendTool — optional)
# ──────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ──────────────────────────────────────────────────────────────────────────────
# Artifact storage directory (defaults to system temp if not set)
# ──────────────────────────────────────────────────────────────────────────────
ARTIFACTS_DIR=/tmp/ai-artifacts

# ──────────────────────────────────────────────────────────────────────────────
# Application port
# ──────────────────────────────────────────────────────────────────────────────
PORT=8080

# ──────────────────────────────────────────────────────────────────────────────
# Spring profile (local | docker)
# ──────────────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
